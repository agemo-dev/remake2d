@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(REMAKE2D_BUILD_SHARED_LIBS @BUILD_SHARED_LIBS@)
set(REMAKE2D_TERMUX_BUILD @TERMUX_BUILD@)

if(REMAKE2D_TERMUX_BUILD)
    find_dependency(SDL2)
    find_dependency(SDL2_image)
    find_dependency(SDL2_mixer)
    find_dependency(SDL2_ttf)
elseif(NOT REMAKE2D_BUILD_SHARED_LIBS)
    find_dependency(SDL2)
    find_dependency(SDL2_image)
    find_dependency(SDL2_mixer)
    find_dependency(SDL2_ttf)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/remake2dTargets.cmake" OPTIONAL)

if(NOT TARGET remake2d::remake2d AND TARGET remake2d)
    add_library(remake2d::remake2d ALIAS remake2d)
endif()

check_required_components(remake2d)